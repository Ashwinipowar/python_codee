n = 153           # The number to check
num = n           # Copy of n to manipulate in the loop
total = 0         # Initialize sum of powered digits to zero

nod = len(str(n)) # Count the number of digits in n by converting to string

while num > 0:    
    id = num % 10             # Extract the last digit of num
    total = total + (id ** nod)  # Raise digit to power 'nod' and add to total
    num = num // 10           # Remove the last digit from num (integer division)

# After the loop, total contains sum of each digit raised to power nod
# Check if total equals original number n
print("this is a armstrog", total == n)


